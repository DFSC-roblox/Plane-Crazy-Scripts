TelemetryFrame.Position = UDim2.new(0.5, -180, 1, -120)
TelemetryFrame.BackgroundTransparency = 1
TelemetryFrame.Active = true
TelemetryFrame.Draggable = true
TelemetryFrame.Parent = MainGui

local function CreateTelemetryLabel(YOffset, DefaultText)
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 0, 24)
    Label.Position = UDim2.new(0, 0, 0, YOffset)
    Label.BackgroundTransparency = 0.4
    Label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Label.TextColor3 = Color3.new(1, 1, 1)
    Label.Font = Enum.Font.Michroma
    Label.TextSize = 16
    Label.TextXAlignment = Enum.TextXAlignment.Center
    Label.Text = DefaultText or "waiting for target.."
    Label.Parent = TelemetryFrame
    Instance.new("UICorner", Label).CornerRadius = UDim.new(0, 6)
    return Label
end

local TargetVelocityLabel = CreateTelemetryLabel(90)
local MissileVelocityLabel = CreateTelemetryLabel(60)
local MissileDistanceLabel = CreateTelemetryLabel(30)

local TargetPlayer = nil
local IsMissileLaunched = false
local MissileSpeed = 100
local MissileSmoothness = 0.1
local PredictionOffset = 0.16
local LaunchTime = 0

TargetTextBox:GetPropertyChangedSignal("Text"):Connect(function()
