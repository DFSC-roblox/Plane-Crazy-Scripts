local function FindAndSetupAircraft()
    local Character = LocalPlayer.Character
    local AircraftModel = nil

    if Character then
        AircraftModel = Character:FindFirstChild("Aircraft") or Workspace:FindFirstChild(LocalPlayer.Name .. " Aircraft")
    end

    if AircraftModel and AircraftModel:FindFirstChild("BlockStd") and AircraftModel.BlockStd:FindFirstChild("BlockStd") then
        local PrimaryPart = AircraftModel.BlockStd.BlockStd
        AircraftModel.PrimaryPart = PrimaryPart
        PrimaryPart.Anchored = false

        local PilotSeat = AircraftModel:FindFirstChild("PilotSeat") or Instance.new("Part")
        for _, Part in ipairs(AircraftModel:GetDescendants()) do
            if Part:IsA("BasePart") and not Part:IsDescendantOf(PilotSeat) and Part ~= PrimaryPart then
                local Weld = Instance.new("WeldConstraint")
                Weld.Part0 = PrimaryPart
                Weld.Part1 = Part
                Weld.Parent = PrimaryPart
            end
        end

        local DetonationPart = AircraftModel:FindFirstChild("ExplosiveBlock") or AircraftModel:GetChildren()[9]

        return AircraftModel, PrimaryPart, DetonationPart
    end
    return nil, nil, nil
end

