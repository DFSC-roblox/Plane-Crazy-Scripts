local function CreateSlider(LabelText, YOffset, ParentFrame, MaxValue, DefaultValue)
    local ContainerLabel, SliderBackground, SliderFill, SliderUpdate
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -20, 0, 30)
    Container.Position = UDim2.new(0, 10, 0, YOffset)
    Container.BackgroundTransparency = 1
    Container.Parent = ParentFrame

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -20, 0, 20)
    Label.Position = UDim2.new(0, 10, 0, YOffset)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.new(1, 1, 1)
    Label.Font = Enum.Font.Michroma
    Label.TextSize = 14
    Label.Text = LabelText .. tostring(DefaultValue)
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ParentFrame

    local Background = Instance.new("TextButton")
    Background.Size = UDim2.new(1, -20, 0, 12)
    Background.Position = UDim2.new(0, 10, 0, YOffset + 22)
    Background.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Background.Text = ""
    Background.Parent = ParentFrame
    Instance.new("UICorner", Background).CornerRadius = UDim.new(0, 6)

    local Fill = Instance.new("Frame")
    Fill.BackgroundColor3 = DEEP_PURPLE
    Fill.Size = UDim2.new(DefaultValue / MaxValue, 0, 1, 0)
    Fill.Parent = Background
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(0, 6)

    local function UpdateSlider(AbsoluteX)
        local RelativeX = math.clamp((AbsoluteX - Background.AbsolutePosition.X) / Background.AbsoluteSize.X, 0, 1)
        TweenService:Create(Fill, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(RelativeX, 0, 1, 0),
        }):Play()

        local Value = math.floor(RelativeX * MaxValue * 100) / 100
        Label.Text = LabelText .. tostring(Value)
        return Value
    end

    return Label, Background, Fill, UpdateSlider
end

