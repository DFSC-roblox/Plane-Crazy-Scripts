    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = Player.Name
    NameLabel.TextColor3 = DEFAULT_COLOR
    NameLabel.Font = Enum.Font.Michroma
    NameLabel.TextSize = 14
    NameLabel.Parent = BillboardGui
    NameLabel.TextStrokeTransparency = 0
    NameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

    NameESP_Guis[Player] = BillboardGui
end

local function DestroyNameESP(Player)
    if NameESP_Guis[Player] then
        NameESP_Guis[Player]:Destroy()
        NameESP_Guis[Player] = nil
    end
end

RunService.RenderStepped:Connect(function()
    if GetNameESPEnabled() then
        for _, Player in ipairs(Players:GetPlayers()) do
            if Player ~= LocalPlayer then
                if not NameESP_Guis[Player] then
