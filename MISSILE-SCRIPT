local MissileESP_Gui = nil

local function CreateMissileESP(Part)
    if not Part or not Part:IsA("BasePart") then return end
    if MissileESP_Gui then
        MissileESP_Gui:Destroy()
        MissileESP_Gui = nil
    end

    local WIDTH = 60
    local HEIGHT = 60
    local THICKNESS = 2

    local BillboardGui = Instance.new("BillboardGui")
    BillboardGui.Name = "MissileESP_Billboard"
    BillboardGui.Adornee = Part
    BillboardGui.Size = UDim2.new(0, WIDTH, 0, HEIGHT)
    BillboardGui.AlwaysOnTop = true
    BillboardGui.LightInfluence = 0
    BillboardGui.MaxDistance = 10000
    BillboardGui.Parent = MainGui

    local FrameContainer = Instance.new("Frame")
    FrameContainer.Size = UDim2.new(1, 0, 1, 0)
    FrameContainer.BackgroundTransparency = 1
    FrameContainer.BorderSizePixel = 0
    FrameContainer.Parent = BillboardGui

    local V1 = Vector2.new(WIDTH / 2, 6)
    local V2 = Vector2.new(10, HEIGHT - 10)
    local V3 = Vector2.new(WIDTH - 10, HEIGHT - 10)

    local function DrawLine(P0, P1)
        local DeltaX = P1.X - P0.X
        local DeltaY = P1.Y - P0.Y
        local Length = math.sqrt(DeltaX * DeltaX + DeltaY * DeltaY)
        local Angle = math.deg(math.atan2(DeltaY, DeltaX))

        local Line = Instance.new("Frame")
        Line.Size = UDim2.new(0, Length, 0, THICKNESS)
        Line.Position = UDim2.new(0, (P0.X + P1.X) / 2, 0, (P0.Y + P1.Y) / 2)
        Line.AnchorPoint = Vector2.new(0.5, 0.5)
        Line.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        Line.BorderSizePixel = 0
        Line.Rotation = Angle
        Line.Parent = FrameContainer
        Line.BackgroundTransparency = 0.6
    end

    DrawLine(V1, V2)
    DrawLine(V2, V3)
    DrawLine(V3, V1)

    MissileESP_Gui = BillboardGui
end

local function DestroyMissileESP()
    if MissileESP_Gui then
        MissileESP_Gui:Destroy()
        MissileESP_Gui = nil
    end
end

local function UpdateMissileESP()
    if GetMissileESPEnabled() then
        if MissilePrimaryPart and MissilePrimaryPart.Parent then
            if not MissileESP_Gui or MissileESP_Gui.Adornee ~= MissilePrimaryPart then
                CreateMissileESP(MissilePrimaryPart)
            end
        else
            DestroyMissileESP()
        end
    else
        DestroyMissileESP()
    end
end

local TargetESP_Gui = nil

local function CreateTargetESP(Part)
    if not Part or not Part:IsA("BasePart") then return end
    if TargetESP_Gui then
        TargetESP_Gui:Destroy()
        TargetESP_Gui = nil
    end

    local WIDTH = 60
    local HEIGHT = 60
    local THICKNESS = 2

    local BillboardGui = Instance.new("BillboardGui")
    BillboardGui.Name = "TargetESP_Billboard"
    BillboardGui.Adornee = Part
    BillboardGui.Size = UDim2.new(0, WIDTH, 0, HEIGHT)
    BillboardGui.AlwaysOnTop = true
    BillboardGui.LightInfluence = 0
    BillboardGui.MaxDistance = 10000
    BillboardGui.Parent = MainGui

    local FrameContainer = Instance.new("Frame")
    FrameContainer.Size = UDim2.new(1, 0, 1, 0)
    FrameContainer.BackgroundTransparency = 1
    FrameContainer.BorderSizePixel = 0
    FrameContainer.Parent = BillboardGui

    local function DrawCornerLine(X, Y, W, H)
        local Line = Instance.new("Frame")
        Line.Size = UDim2.new(0, W, 0, H)
        Line.Position = UDim2.new(0, X, 0, Y)
        Line.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        Line.BackgroundTransparency = 0.6
        Line.BorderSizePixel = 0
        Line.Parent = FrameContainer
    end

    DrawCornerLine(0, 0, WIDTH, THICKNESS)
    DrawCornerLine(0, HEIGHT - THICKNESS, WIDTH, THICKNESS)
    DrawCornerLine(0, 0, THICKNESS, HEIGHT)
    DrawCornerLine(WIDTH - THICKNESS, 0, THICKNESS, HEIGHT)

    TargetESP_Gui = BillboardGui
end

local function DestroyTargetESP()
    if TargetESP_Gui then
        TargetESP_Gui:Destroy()
        TargetESP_Gui = nil
    end
end

local function UpdateTargetESP()
    if GetTargetESPEnabled() then
        if PredictionBall and PredictionBall.Parent then
            if not TargetESP_Gui or TargetESP_Gui.Adornee ~= PredictionBall then
                CreateTargetESP(PredictionBall)
            end
        else
            DestroyTargetESP()
        end
    else
        DestroyTargetESP()
    end
end

local MissileTrailLifetime = 7
local MissileTrailWidth = 0.5
local MissileTrailBrightness = 2
local MissileTrailSystem = {}

local function CreateMissileTrail()
    if MissileTrailSystem.Trail then return end

    local Part1 = Instance.new("Part")
    Part1.Name = "MissileTrailAnchor1"
    Part1.Size = Vector3.new(0.2, 0.2, 0.2)
    Part1.Transparency = 1
    Part1.Anchored = true
    Part1.CanCollide = false
    Part1.Parent = Workspace

    local Part2 = Part1:Clone()
    Part2.Name = "MissileTrailAnchor2"
    Part2.Parent = Workspace

    local Attachment1 = Instance.new("Attachment", Part1)
    local Attachment2 = Instance.new("Attachment", Part2)

    local Trail = Instance.new("Trail")
    Trail.Name = "MissileTrail"
    Trail.Attachment0 = Attachment1
    Trail.Attachment1 = Attachment2
    Trail.FaceCamera = true
    Trail.Lifetime = MissileTrailLifetime
    Trail.MinLength = 0.1
    Trail.LightInfluence = 0
    Trail.Brightness = MissileTrailBrightness
    Trail.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.2),
        NumberSequenceKeypoint.new(0.8, 0.6),
        NumberSequenceKeypoint.new(1, 1)
    })
    Trail.Color = ColorSequence.new(DEFAULT_COLOR)
    Trail.WidthScale = NumberSequence.new(MissileTrailWidth)
    Trail.Parent = Workspace

    MissileTrailSystem = {
        Part1 = Part1,
        Part2 = Part2,
        Trail = Trail,
    }
end

local function DestroyMissileTrail()
    for _, Instance in pairs(MissileTrailSystem) do
        if typeof(Instance) == "Instance" and Instance.Parent then
            Instance:Destroy()
        end
    end
    MissileTrailSystem = {}
end

local function UpdateMissileTrail()
    if not GetMissileTrailEnabled() then
        DestroyMissileTrail()
        return
    end

    if MissilePrimaryPart and MissilePrimaryPart.Parent then
        CreateMissileTrail()

        local CFrame = MissilePrimaryPart.CFrame
        local TailPosition = CFrame.Position - CFrame.LookVector * (MissilePrimaryPart.Size.Z / 2 + 0.12)

        local LeftOffset = CFrame.RightVector * -0.25
        local RightOffset = CFrame.RightVector * 0.25

        if MissileTrailSystem.Part1 then
            MissileTrailSystem.Part1.Position = TailPosition + LeftOffset
        end
        if MissileTrailSystem.Part2 then
            MissileTrailSystem.Part2.Position = TailPosition + RightOffset
        end
        if MissileTrailSystem.Trail then
            MissileTrailSystem.Trail.Color = ColorSequence.new(DEFAULT_COLOR)
        end
    else
        DestroyMissileTrail()
    end
end

local function UpdateMissileCollision()
    if not AircraftModel then return end

    local CanCollide = not GetNoCollisionEnabled()
    for _, Part in ipairs(AircraftModel:GetDescendants()) do
        if Part:IsA("BasePart") then
            Part.CanCollide = CanCollide
        end
    end
end

local LIFT_VELOCITY = 7
local LIFT_DURATION = 0.5

RunService.Heartbeat:Connect(function()
    if IsMissileLaunched and MissilePrimaryPart and TargetPlayer and TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("HumanoidRootPart") then

        local TargetRootPart = TargetPlayer.Character.HumanoidRootPart
        local TargetVelocity = TargetRootPart.AssemblyLinearVelocity
        local MissileVelocity = MissilePrimaryPart.AssemblyLinearVelocity

        if tick() - LaunchTime < LIFT_DURATION then
            MissilePrimaryPart.AssemblyLinearVelocity = Vector3.new(0, LIFT_VELOCITY, 0)
        else
            local PredictedPosition = CalculateTargetPrediction(TargetRootPart.Position, TargetVelocity, MissilePrimaryPart.Position, MissileSpeed)
            PredictionBall.Position = PredictedPosition

            local LocalPlayerRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if LocalPlayerRoot then
                local DistanceRatio = math.clamp(((LocalPlayerRoot.Position - PredictedPosition)).Magnitude / 30, 10, 20)
                PredictionBall.Size = Vector3.new(DistanceRatio, DistanceRatio, DistanceRatio)
            end

            local DirectionToTarget = (PredictedPosition - MissilePrimaryPart.Position).Unit
            local TargetVelocityVector = DirectionToTarget * MissileSpeed

            MissilePrimaryPart.AssemblyLinearVelocity = MissileVelocity:Lerp(TargetVelocityVector, MissileSmoothness)

            if DetonationPart and DetonationPart:IsA("BasePart") then
                MissilePrimaryPart.CFrame = CFrame.new(MissilePrimaryPart.Position, PredictedPosition)
            end

            TargetVelocityLabel.Text = string.format("TargetVel: (%.0f, %.0f, %.0f)", TargetVelocity.X, TargetVelocity.Y, TargetVelocity.Z)
            MissileVelocityLabel.Text = string.format("MissileVel: (%.0f, %.0f, %.0f)", MissileVelocity.X, MissileVelocity.Y, MissileVelocity.Z)
            local Distance = (MissilePrimaryPart.Position - PredictedPosition).Magnitude
            MissileDistanceLabel.Text = "Distance: " .. math.floor(Distance)

            if GetAutoDetonateEnabled() and Distance <= 4 then
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.K, false, game)
                task.wait()
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.K, false, game)
            end
        end
    else
        TargetVelocityLabel.Text = "n/a"
        MissileVelocityLabel.Text = "n/a"
        MissileDistanceLabel.Text = "n/a"
    end

    pcall(UpdateMissileESP)
    pcall(UpdateTargetESP)
end)

Workspace.ChildAdded:Connect(function(Child)
    if Child.Name == LocalPlayer.Name .. " Aircraft" then
        task.wait(0.5)
        AircraftModel, MissilePrimaryPart, DetonationPart = FindAndSetupAircraft()
        pcall(UpdateMissileESP)
    end
end)

RunService.Heartbeat:Connect(function()
    pcall(UpdateMissileESP)
    pcall(UpdateTargetESP)
    pcall(UpdateMissileTrail)
    UpdateMissileCollision()
end)
