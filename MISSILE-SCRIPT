    local DropdownButton = Instance.new("TextButton")
    DropdownButton.Size = UDim2.new(0.5, 0, 1, 0)
    DropdownButton.Position = UDim2.new(0.5, 0, 0, 0)
    DropdownButton.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    DropdownButton.TextColor3 = Color3.fromRGB(220, 220, 220)
    DropdownButton.Font = Enum.Font.Michroma
    DropdownButton.TextSize = 14
    DropdownButton.AutoButtonColor = false
    DropdownButton.Parent = Container
    Instance.new("UICorner", DropdownButton).CornerRadius = UDim.new(0, 6)

    local IsDropdownOpen = false
    local DropdownContentFrame = Instance.new("Frame")
    DropdownContentFrame.Size = UDim2.new(1, -20, 0, 0)
    DropdownContentFrame.Position = UDim2.new(0, 10, 0, 30)
    DropdownContentFrame.BackgroundTransparency = 1
    DropdownContentFrame.ClipsDescendants = true
    DropdownContentFrame.Parent = ParentFrame

    local function ToggleDropdown()
        IsDropdownOpen = not IsDropdownOpen
        local TargetSize = UDim2.new(1, -20, 0, IsDropdownOpen and #ColorOptions * 28 or 0)
        TweenService:Create(DropdownContentFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = TargetSize
        }):Play()
    end

    DropdownButton.MouseButton1Click:Connect(ToggleDropdown)

    for Index, Option in ipairs(ColorOptions) do
        local ItemButton = Instance.new("TextButton")
        ItemButton.Size = UDim2.new(1, 0, 0, 28)
        ItemButton.Position = UDim2.new(0, 0, 0, (Index - 1) * 28)
        ItemButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        ItemButton.TextColor3 = Color3.fromRGB(230, 230, 230)
        ItemButton.Font = Enum.Font.Michroma
        ItemButton.TextSize = 14
        ItemButton.Text = Option.label
        ItemButton.Parent = DropdownContentFrame
        Instance.new("UICorner", ItemButton).CornerRadius = UDim.new(0, 6)

        ItemButton.MouseEnter:Connect(function()
            ItemButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        end)
        ItemButton.MouseLeave:Connect(function()
            ItemButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        end)

        ItemButton.MouseButton1Click:Connect(function()
            DropdownButton.Text = Option.label
            ToggleDropdown()

            -- Handle rainbow toggle
            if Option.label == "RAINBOW" then
                IS_RAINBOW = true
            else
                IS_RAINBOW = false
                DEFAULT_COLOR = Option.color
            end

            for _, Gui in pairs(NameESP_Guis) do
                local NameLabel = Gui:FindFirstChildOfClass("TextLabel")
                if NameLabel then
                    NameLabel.TextColor3 = DEFAULT_COLOR
                end
            end

            pcall(function()
                DestroyMissileTrail()
            end)
            if GetMissileTrailEnabled() and MissilePrimaryPart and MissilePrimaryPart.Parent then
                pcall(function()
                    CreateMissileTrail()
                    if MissileTrailSystem.Trail then
                        MissileTrailSystem.Trail.Color = ColorSequence.new(DEFAULT_COLOR)
                    end
                end)
            end
        end)
    end

    DropdownButton.Text = ColorOptions[DefaultIndex].label
    DEFAULT_COLOR = ColorOptions[DefaultIndex].color

    return {
        getSelected = function()
            return DropdownButton.Text
        end,
        setSelected = function(Index)
            Index = math.clamp(Index, 1, #ColorOptions)
            DropdownButton.Text = ColorOptions[Index].label
            if ColorOptions[Index].label == "RAINBOW" then
                IS_RAINBOW = true
            else
                IS_RAINBOW = false
                DEFAULT_COLOR = ColorOptions[Index].color
            end

            for _, Gui in pairs(NameESP_Guis) do
                local NameLabel = Gui:FindFirstChildOfClass("TextLabel")
                if NameLabel then
                    NameLabel.TextColor3 = DEFAULT_COLOR
                end
            end
        end,
    }
end

