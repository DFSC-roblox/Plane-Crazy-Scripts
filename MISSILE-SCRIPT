        if TargetPlayer then
            IsMissileLaunched = true
            LaunchTime = tick()
        end
    end
end)

local function CalculateTargetPrediction(TargetPos, TargetVel, MissilePos, MissileSpeed)
    return TargetPos + TargetVel * PredictionOffset
end

