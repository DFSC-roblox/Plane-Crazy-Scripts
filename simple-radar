Instance.new("UICorner", Close)

local Range = 500
local PlayerBlips = {} -- Table to track dots and their timings

-- Logic to calculate if the needle is "hitting" a coordinate
local function getAngle(v2)
    return math.deg(math.atan2(v2.Y, v2.X))
end

local Connection
Connection = RunService.RenderStepped:Connect(function()
    NeedleContainer.Rotation = (NeedleContainer.Rotation + 1) % 360
    local currentNeedleAngle = (NeedleContainer.Rotation) % 360
    
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local myPos = char.HumanoidRootPart.Position

    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local ePos = p.Character.HumanoidRootPart.Position
            local diff = ePos - myPos
            local dist2D = Vector2.new(diff.X, diff.Z)
            
            if dist2D.Magnitude < Range then
                -- Calculate UI position
                local bX = (diff.X / Range) * (MainFrame.AbsoluteSize.X / 2)
                local bY = (diff.Z / Range) * (MainFrame.AbsoluteSize.Y / 2)
                
                -- Calculate Angle of the Player relative to you
                -- Note: We adjust by 90 to match Roblox UI rotation math
                local playerAngle = (getAngle(dist2D) + 90) % 360
                
                -- Create blip if it doesn't exist
                if not PlayerBlips[p.UserId] then
                    local Blip = Instance.new("Frame")
                    Blip.Name = "TargetBlip"
                    Blip.Size = UDim2.new(0, 6, 0, 6)
                    Blip.AnchorPoint = Vector2.new(0.5, 0.5)
                    Blip.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                    Blip.BackgroundTransparency = 1 -- Start hidden
                    Blip.ZIndex = 5
                    Blip.Parent = MainFrame
                    Instance.new("UICorner", Blip).CornerRadius = UDim.new(1, 0)
                    
                    PlayerBlips[p.UserId] = {Gui = Blip, LastSeen = 0}
                end
                
                local data = PlayerBlips[p.UserId]
                data.Gui.Position = UDim2.new(0.5, bX, 0.5, bY)
                
                -- Check if needle is passing over the player
                local angleDiff = math.abs(currentNeedleAngle - playerAngle)
                if angleDiff < 10 or angleDiff > 350 then
                    data.LastSeen = tick()
                end
                
                -- Fade logic (Fades out over 2 seconds)
                local timeSinceSeen = tick() - data.LastSeen
                local transparency = math.clamp(timeSinceSeen / 2, 0, 1)
                data.Gui.BackgroundTransparency = transparency
            end
        end
    end
    
    -- Clean up blips for players who left
    for id, data in pairs(PlayerBlips) do
        if not game:GetService("Players"):GetPlayerByUserId(id) then
            data.Gui:Destroy()
            PlayerBlips[id] = nil
        end
    end
end)

Close.MouseButton1Click:Connect(function()
    Connection:Disconnect()
    ScreenGui:Destroy()
end)
